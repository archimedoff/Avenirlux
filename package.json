{
  "name": "travel-hotel-website-project",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "dotenv -e .env.local -- tsx scripts/run-with-database-url.ts -- prisma db push",
    "db:migrate": "dotenv -e .env.local -- tsx scripts/run-with-database-url.ts -- prisma migrate dev",
    "db:seed": "dotenv -e .env.local -- tsx scripts/run-with-database-url.ts -- npx tsx prisma/seed.ts",
    "db:import": "dotenv -e .env.local -- tsx scripts/run-with-database-url.ts -- npx tsx scripts/import-json-to-db.ts",
    "security:check": "bash scripts/check-secrets.sh",
    "db:verify": "dotenv -e .env.local -- npx tsx scripts/verify-db.ts",
    "db:urls": "dotenv -e .env.local -- npx tsx scripts/compose-database-urls.ts",
    "db:sync-env": "dotenv -e .env.local -- tsx scripts/sync-supabase-env.ts",
    "storage:ensure-bucket": "dotenv -e .env.local -- npx tsx scripts/ensure-storage-bucket.ts",
    "verify:hotels": "dotenv -e .env.local -- npx tsx scripts/verify-live-hotels.ts",
    "verify:production": "dotenv -e .env.local -- npx tsx scripts/verify-production-readiness.ts",
    "smoke:production": "npx tsx scripts/smoke-test-production.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@stripe/react-stripe-js": "^6.5.0",
    "@stripe/stripe-js": "^9.7.0",
    "@supabase/supabase-js": "^2.106.2",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "next": "^16.2.4",
    "next-auth": "^5.0.0-beta.30",
    "openai": "^6.39.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "resend": "^6.12.4",
    "server-only": "^0.0.1",
    "stripe": "^22.2.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
