{
  "name": "travel-hotel-website-project",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:seed": "dotenv -e .env.local -- npx tsx prisma/seed.ts",
    "db:import": "dotenv -e .env.local -- npx tsx scripts/import-json-to-db.ts",
    "security:check": "bash scripts/check-secrets.sh",
    "db:verify": "dotenv -e .env.local -- npx tsx scripts/verify-db.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "next": "^16.2.4",
    "next-auth": "^5.0.0-beta.30",
    "openai": "^6.39.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
