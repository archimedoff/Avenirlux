# LiteAPI — required for live hotel search
LITE_API_KEY=your_sandbox_or_production_key
# LITE_API_BASE_URL=https://api.liteapi.travel/v3.0

# Auth.js — generate: openssl rand -base64 32
AUTH_SECRET=

# Comma-separated admin emails
ADMIN_EMAILS=admin@avenirlux.com

# Site URL (production: https://avenirlux.com)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Auth.js canonical URL (production: https://avenirlux.com)
AUTH_URL=http://localhost:3000

# Google OAuth — callbacks: {AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Or: AUTH_GOOGLE_ID= / AUTH_GOOGLE_SECRET=
AUTH_APPLE_ID=
AUTH_APPLE_SECRET=
AUTH_FACEBOOK_ID=
AUTH_FACEBOOK_SECRET=
AUTH_TWITTER_ID=
AUTH_TWITTER_SECRET=

# AI Concierge — OpenAI (falls back to curated mock if unset)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# OPENAI_TIMEOUT_MS=55000
# CONCIERGE_RATE_LIMIT_PER_MINUTE=30

# Supabase PostgreSQL (Prisma)
# Supabase Postgres (recommended — password separate, auto-encoded)
# SUPABASE_PROJECT_REF=your_project_ref
# SUPABASE_POOLER_HOST=aws-1-eu-central-1.pooler.supabase.com
# SUPABASE_DB_PASSWORD=your_database_password
# SUPABASE_DB_HOST=db.your_project_ref.supabase.co
# Or full URIs (URL-encode special characters in password):
# DATABASE_URL=postgresql://postgres.[ref]:[ENCODED]@....pooler.supabase.com:6543/postgres?pgbouncer=true
# DIRECT_URL=postgresql://postgres.[ref]:[ENCODED]@....pooler.supabase.com:5432/postgres

# Supabase Storage (property image uploads)
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STORAGE_BUCKET=property-images
